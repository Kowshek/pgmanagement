# Database Configuration (points to the docker-compose postgres service)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/pgmanager

# JWT Configuration
JWT_SECRET=super_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis Configuration (points to the docker-compose redis service)
REDIS_URL=redis://redis:6379/0